-- // NEMESIS V20 PRO - INTEGRATED // --
local Library = loadstring(game:HttpGet('https://raw.githubusercontent.com/wally-rblx/LinoriaLib/main/Library.lua'))()

local Player = game:GetService("Players").LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")
local HttpService = game:GetService("HttpService")
local VirtualUser = game:GetService("VirtualUser")

-- Globale Config
local WEBHOOK_URL = getgenv().webhook
local USER_ID = getgenv().discordId
local KEY_INPUT = getgenv().script_key

-- [UI SETUP]
local Window = Library:CreateWindow({
    Title = 'Nemesis System | V20 Pro',
    Center = true,
    AutoShow = true,
})

local MainTab = Window:AddTab('Hauptsteuerung')
local LogGroup = MainTab:AddLeftGroupbox('System-Log')
local CodeGroup = MainTab:AddRightGroupbox('Status & Info')

-- [LOGGING FUNKTION]
local LogList = {}
local function log(text)
    table.insert(LogList, 1, text)
    if #LogList > 10 then table.remove(LogList) end
    LogGroup:AddLabel(text) -- Fügt dem Linoria-Fenster eine Zeile hinzu
end

-- [WEBHOOK LOGIK]
local function sendSuccessWebhook(code)
    local data = {
        ["username"] = "Auto Redeem by Nemesis",
        ["avatar_url"] = "https://github.com/9Nexus7/image/blob/main/Screenshot%202026-07-14%20122613.png",
        ["embeds"] = {{
            ["title"] = "✅ NEMESIS REDEEM SUCCESS",
            ["description"] = "User: <@" .. USER_ID .. ">\nCode erfolgreich eingelöst: " .. code,
            ["color"] = 65280
        }}
    }
    pcall(function() request({Url = WEBHOOK_URL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)}) end)
end

-- [REDEEM & DETEKTOR]
local codeBuffer = ""

local function performRedeem(fullCode)
    local target = PlayerGui:FindFirstChild("Codes", true) or PlayerGui:FindFirstChild("CodeFrame", true)
    if target then
        local box = target:FindFirstChildWhichIsA("TextBox", true)
        local btn = target:FindFirstChild("Submit", true) or target:FindFirstChild("Redeem", true) or target:FindFirstChild("Enter", true)
        if box then
            box.Text = fullCode
            log("Versuch: " .. fullCode)
            if btn then VirtualUser:ClickButton1(Vector2.new(btn.AbsolutePosition.X, btn.AbsolutePosition.Y)) end
        end
    end
end

PlayerGui.DescendantAdded:Connect(function(obj)
    if obj:IsA("TextLabel") and (obj.Text:lower():find("success") or obj.Text:lower():find("redeemed")) then
        sendSuccessWebhook(codeBuffer)
        codeBuffer = ""
    end
end)

local function processText(text)
    for word in text:gmatch("%S+") do
        local lw = word:lower()
        if #word >= 3 and lw ~= "user" and lw ~= "code" and lw ~= "teil" then
            codeBuffer = codeBuffer .. word
            performRedeem(codeBuffer)
        end
    end
    task.delay(30, function() codeBuffer = "" end)
end

-- [STARTUP]
if KEY_INPUT ~= "Nexus" then
    Player:Kick("Falscher Key!")
else
    Library:Notify("Nemesis V20 System Online")
    
    for _, obj in pairs(PlayerGui:GetDescendants()) do
        if obj:IsA("TextLabel") and (obj.Name:lower():find("announce") or obj.Name:lower():find("alert")) then
            obj:GetPropertyChangedSignal("Text"):Connect(function() processText(obj.Text) end)
        end
    end
end

-- Damit man das Menü mit "Insert" öffnen kann:
Library:SetWatermark("Nemesis V20 Pro")
Library.KeybindFrame.Visible = true
