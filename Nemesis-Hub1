local function verify_license()
    local body = HttpService:JSONEncode({
        key = LICENSE_KEY,
        hwid = "ROBLOX-" .. tostring(Player.UserId)
    })

    local success, response = pcall(function()
        return request({
            Url = API_URL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json",
                ["X-API-Key"] = API_SECRET
            },
            Body = body
        })
    end)

    if not success or response.StatusCode ~= 200 then
        Player:Kick("Lizenz-Server nicht erreichbar oder Key ungültig!")
        return false
    end

    local result = HttpService:JSONDecode(response.Body)
    if result and result.valid then
        return true
    else
        Player:Kick("Lizenzprüfung fehlgeschlagen: " .. (result.reason or "Unbekannter Fehler"))
